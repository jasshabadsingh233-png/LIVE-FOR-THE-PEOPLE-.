import streamlit as st

# 1. UI Setup
st.set_page_config(page_title="LFP Shield")

# 2. Safety Logic (The Option B Engine)
def get_shield(price, sentiment):
    # Multiplier: 1x for Crisis, 2x for Stable
    mult = 1.0 if sentiment < -0.5 else 2.0
    return price - (45.0 * mult)

# 3. Content Rendering
st.title("🛡️ LFP: Investor Shield")
st.write("Solo Founder Prototype | Kuala Lumpur Demo")

# Manual Inputs
val = st.number_input("Current Market Price (₹)", value=2950.0)
news = st.slider("AI News Sentiment Score", -1.0, 1.0, 0.0)

# Output Calculation
shield_val = get_shield(val, news)

st.divider()

# Big Performance Metrics
c1, c2 = st.columns(2)
c1.metric("Live Price", f"₹{val}")
c2.metric("Safety Floor", f"₹{shield_val}", delta=f"{round(val-shield_val, 2)} Buffer")

# Status Narrative
if news < -0.5:
    st.error("STATUS: 100% PROTECTED (EXIT TRIGGERED)")
    st.write("AI detected a systemic crisis. Hard stop moved to immediate exit.")
else:
    st.success("STATUS: GROWTH MODE (TRAILING FLOOR ACTIVE)")
    st.write("Market stable. Strategy: Trailing Floor at 2.0x ATR.")
