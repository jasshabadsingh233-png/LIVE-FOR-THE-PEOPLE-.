import streamlit as st
import yfinance as yf
import plotly.express as px
import pandas as pd

st.title("🛡️ LFP: Performance Telemetry")

ticker_input = st.sidebar.text_input("Ticker", "RELIANCE")
ticker_ns = f"{ticker_input}.NS"

# 1. FETCH DATA
with st.spinner(f"Pulling {ticker_input} from NSE..."):
    # We use 1mo to ensure we have enough data points for a line
    data = yf.download(ticker_ns, period="1mo", interval="1d")

# 2. DEBUGGING CHECK
if data.empty:
    st.error(f"No data found for {ticker_ns}. Check the ticker symbol.")
else:
    # Handle the 'MultiIndex' issue in newer yfinance versions
    if isinstance(data.columns, pd.MultiIndex):
        data.columns = data.columns.get_level_values(0)

    # 3. CALCULATE OPTION B FLOOR
    # Logic: Current Close - (Average Volatility * 2)
    data['Safety Floor'] = data['Close'] * 0.96 # Demo logic: 4% protection gap

    # 4. RENDER CHART
    try:
        # We need a clean DataFrame for Plotly
        plot_df = data[['Close', 'Safety Floor']].reset_index()
        
        fig = px.line(
            plot_df, 
            x='Date', 
            y=['Close', 'Safety Floor'],
            title=f"LFP Risk Shield: {ticker_input}",
            color_discrete_map={"Close": "#0000FF", "Safety Floor": "#FF0000"}
        )
        
        st.plotly_chart(fig, use_container_width=True)
        
        # 5. LIVE STATS
        latest_price = round(data['Close'].iloc[-1], 2)
        latest_floor = round(data['Safety Floor'].iloc[-1], 2)
        st.metric("Current Market Price", f"₹{latest_price}", delta=f"Shield at ₹{latest_floor}")

    except Exception as e:
        st.error(f"Chart Render Error: {e}")
